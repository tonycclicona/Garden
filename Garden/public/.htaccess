# ============================================================
# Bearded Mountaineer Lodge — Apache Configuration
# Next.js Static Export + WordPress Headless CMS
# Coexistencia en el mismo public_html/
# ============================================================

# Desactivar listado de directorios
Options -Indexes

# index.html tiene prioridad sobre index.php (Next.js gana en la raíz)
DirectoryIndex index.html index.php

RewriteEngine On
RewriteBase /

# ——— Forzar HTTPS ———
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ——— Archivos físicos: servir directamente ———
# Cubre: JS, CSS, imágenes, wp-login.php, wp-config.php, etc.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ——— Directorios físicos: servir directamente ———
# Cubre: wp-admin/, wp-content/, wp-includes/, _next/, foto/, etc.
# Apache aplica DirectoryIndex → index.html prevalece sobre index.php
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ——— Rutas Next.js: /ruta/ → /ruta/index.html ———
# Para URLs que no son archivos/directorios pero tienen index.html pre-renderizado
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}index.html -f
RewriteRule ^ %{DOCUMENT_ROOT}%{REQUEST_URI}index.html [L]

# ——— WordPress fallback: todo lo demás va a index.php ———
# Esto permite que wp-json/, feeds, sitemaps y otras rutas dinámicas de WP funcionen
RewriteRule ^ index.php [L]

# ——— 404: usar la página de Next.js ———
ErrorDocument 404 /404/index.html

# ============================================================
# Caché y Rendimiento
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: sin caché (siempre actualizado)
  ExpiresByType text/html                "access plus 0 seconds"

  # Assets JS/CSS de Next.js con hash: 1 año (immutable)
  <FilesMatch "\.(js|mjs|css|woff2|woff|ttf|otf|eot)$">
    ExpiresDefault "access plus 1 year"
    Header append Cache-Control "immutable"
  </FilesMatch>

  # Imágenes: 1 año
  ExpiresByType image/jpeg               "access plus 1 year"
  ExpiresByType image/png                "access plus 1 year"
  ExpiresByType image/webp               "access plus 1 year"
  ExpiresByType image/gif                "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType image/x-icon             "access plus 1 year"
</IfModule>

# ——— Compresión GZIP ———
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ——— Cabeceras de seguridad ———
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
